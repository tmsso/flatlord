# Flatlord environment — copy to .env.local and fill in. NEVER commit real secrets.
# All values below are placeholders. Real values live outside version control.

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only; never exposed to the client
SUPABASE_DB_URL=                    # direct Postgres connection (migrations/seed)

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (Resend) ───
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── AI (OpenRouter) ───
OPENROUTER_API_KEY=
OPENROUTER_MODEL=                   # configurable model id (e.g. meter OCR)

# ─── Error tracking (Sentry) ───
NEXT_PUBLIC_SENTRY_DSN=

# ─── Golden tests ───
# Points to a CSV fixture. Locally may point at /private/sheet-export.csv;
# in CI ALWAYS the synthetic fixture in ./fixtures.
GOLDEN_SHEET_FIXTURE=./fixtures/sheet-demo.csv
